import java.util.*;

public class LinkedListRemove {
    public static void main(String[] args) {
        LinkedList<Integer> list = new LinkedList<>(Arrays.asList(10,20,30,40));

        list.removeFirst();
        list.removeLast();
        list.remove(Integer.valueOf(20));

        System.out.println("After removal: " + list);
    }
}
